  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/runner": "4.1.4",
    "@vitest/ui": "4.1.4",
    "allure": "3.5.0",
    "allure-playwright": "3.7.1",
    "allure-vitest": "3.7.1",
    "del": "6.0.0",
    "escape-string-regexp": "5.0.0",
    "eslint": "8.57.1",
    "eslint-config-google": "0.14.0",
